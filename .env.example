# ===============================================================
# Sport-Stock Unified Environment Config
# Copy to .env and fill in values. Never commit .env.
# ===============================================================

# --- Database (Postgres) ---
DB_HOST=localhost
DB_PORT=6432
DB_NAME=sportstock
DB_USER=sportstock
DB_PASSWORD=localdev

# --- Services ---
SERVICES_BASE_URL=http://localhost

# Ingestion Service
INGESTION_SERVICE_PORT=8090

# League Service
LEAGUE_SERVICE_PORT=8100

# Transaction Service
TRANSACTION_SERVICE_PORT=8110

# User Authentication Service
USER_AUTH_PORT=8120
JWT_SECRET_KEY=change_me_to_a_very_long_random_secret_123456

# Stock Market Service
STOCK_MARKET_SERVICE_PORT=8130